---
import './src/styles/global.css';
import {ClientRouter} from 'astro:transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>El Redil Laureles - Iglesia Bautista</title>
		<ClientRouter />
	</head>
	<body>
		<nav class="mt-4 py-2 flex justify-between items-center max-inline-nav">
			<img width="150" src="/redil-blue.svg" alt="logo principal del Redil Laureles">
			<a href="/ingreso" class="py-3 px-5 bg-blue-200 rounded-4xl"> Ingreso</a>
		  </nav>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	.max-inline-nav {
		max-inline-size: 1125px;
		margin: 0 auto;
	}
</style>
